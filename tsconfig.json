{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2020"],
        "outDir": "dist",
        "rootDir": "./src",
        "noImplicitAny": true,
        "strictNullChecks": true,
        "declaration": true,
        "isolatedModules": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmit": false,

        /* Strictness & Safety */
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,

        /* Support for NestJS / Frameworks */
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "**/*.test.ts"]
}