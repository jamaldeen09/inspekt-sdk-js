{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2020"],
        "outDir": "dist",
        "rootDir": "./src", 
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "strictNullChecks": true,
        "declaration": true,
        "isolatedModules": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmit": false,
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}